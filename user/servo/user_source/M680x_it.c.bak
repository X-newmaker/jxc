	  DI5_Force = (Servo.Pn01.DI6Ctrl.Data%1000)/100;
	  DI6_Force = (Servo.Pn01.DI7Ctrl.Data%1000)/100;
	  DI7_Force = (Servo.Pn01.DI8Ctrl.Data%1000)/100;
