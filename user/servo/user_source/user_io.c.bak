void DesignGpio(void)//以下引脚规划参数号与说明书接线图一一对应
{
	int32_t *DI_ptr = &IoDi.DI_SON;
	int32_t *DO_ptr = &IoDo.SRDY;
	if(DI0_Force == 0)
	{
		 if(Io_Input0_Dir == 0)
		 {
				if(gpio_get_val(DI1) == GPIO_LEVEL_LOW)
				{
					 if(PinFilterCnt0 >= Servo.Pn01.DIFilterTime.Data)
					 {
							 *(DI_ptr+Io_Input0_State -1) = 1;
							 Io_Input_state = Io_Input_state | 0x1;
					 }
					 else
					 {
							 PinFilterCnt0++;
					 }
				}
				else if(gpio_get_val(DI1) == 1)
				{
					 PinFilterCnt0 = 0;
					 *(DI_ptr+Io_Input0_State -1) = 0;
					 Io_Input_state = Io_Input_state & 0x7e;
				}
		 }
		 else if(Io_Input0_Dir == 1)
		 {
				 if(gpio_get_val(DI1) == 1)
				{
					 if(PinFilterCnt0 >= Servo.Pn01.DIFilterTime.Data)
					 {
						 *(DI_ptr+Io_Input0_State -1) = 1;
						 Io_Input_state = Io_Input_state & 0x7e;
					 }
					 else
					 {
							 PinFilterCnt0++;
					 }
				}
				else if(gpio_get_val(DI1) == 0)
				{
					 PinFilterCnt0 = 0;
					 *(DI_ptr+Io_Input0_State -1) = 0;
					 Io_Input_state = Io_Input_state | 0x1;
				}
		 }
	}
	else if(DI0_Force == 1) //DI2强制有效
	{
		*(DI_ptr+Io_Input0_State -1) = 1;
	}
	if(DI1_Force == 0)
	{
		 if(Io_Input1_Dir == 0)
		 {
				if(gpio_get_val(DI2) == 0)
				{
					 if(PinFilterCnt1 >= Servo.Pn01.DIFilterTime.Data)
					 {
							 *(DI_ptr+Io_Input1_State -1) = 1;
							 Io_Input_state = Io_Input_state | 0x2;
					 }
					 else
					 {
							 PinFilterCnt1++;
					 }
				}
				else if(gpio_get_val(DI2) == 1)
				{
					 PinFilterCnt1 = 0;
					 *(DI_ptr+Io_Input1_State -1) = 0;
					 Io_Input_state = Io_Input_state & 0x7d;
				}
		 }
		 else if(Io_Input1_Dir == 1)
		 {
				 if(gpio_get_val(DI2) == 1)
				{
					 if(PinFilterCnt1 >= Servo.Pn01.DIFilterTime.Data)
					 {
						 *(DI_ptr+Io_Input1_State -1) = 1;
						 Io_Input_state = Io_Input_state & 0x7d;
					 }
					 else
					 {
							 PinFilterCnt1++;
					 }
				}
				else if(gpio_get_val(DI2) == 0)
				{
					 PinFilterCnt1 = 0;
					 *(DI_ptr+Io_Input1_State -1) = 0;
					 Io_Input_state = Io_Input_state | 0x2;
				}
		 }
	}
	else if(DI1_Force == 1) //DI2强制有效
	{
		*(DI_ptr+Io_Input1_State -1) = 1;
	}

	if(DO0_Force == 1)//DO1
	{
	  if(Io_Output0_Dir == 0)
		{
			gpio_set_val(DO1,GPIO_LEVEL_LOW);
		}
		else
		{
			gpio_set_val(DO1,GPIO_LEVEL_HIGH);
		}
	}
	else
	{
	   if(*(DO_ptr+Io_Output0_State -1) == 1)
		{
			 if(Io_Output0_Dir == 0)
			 {
					gpio_set_val(DO1,GPIO_LEVEL_HIGH);
					DISP_DO1 = 1;
			 }
			 else
			 {
					gpio_set_val(DO1,GPIO_LEVEL_LOW);
					DISP_DO1 = 0;
			 }
		}
		else
		{
			 if(Io_Output0_Dir == 0)
			 {
					gpio_set_val(DO1,GPIO_LEVEL_LOW);
					DISP_DO1 = 0;
			 }
			 else
			 {
					gpio_set_val(DO1,GPIO_LEVEL_HIGH);
					DISP_DO1 = 1;
			 }
		}
	}

	if(DO1_Force == 1)
	{
		if(Io_Output1_Dir == 0)
		{
			 gpio_set_val(DO2,GPIO_LEVEL_LOW);
		}
		else
		{
			 gpio_set_val(DO2,GPIO_LEVEL_HIGH);
		}
	}
	else
	{
		if(*(DO_ptr+Io_Output1_State -1) == 1)
		{
			 if(Io_Output1_Dir == 0)
			 {
				 gpio_set_val(DO2,GPIO_LEVEL_HIGH);
				 DISP_DO2 = 1;
			 }
			 else
			 {
				 gpio_set_val(DO2,GPIO_LEVEL_LOW);
				 DISP_DO2 = 0;
			 }
		}
		else
		{
			 if(Io_Output1_Dir == 0)
			 {
				 gpio_set_val(DO2,GPIO_LEVEL_LOW);
				 DISP_DO2 = 0;
			 }
			 else
			 {
				 gpio_set_val(DO2,GPIO_LEVEL_HIGH);
				 DISP_DO2 = 1;
			 }
		}
	}


}
void CheckMotorAlarm(void)
{
	   if(Servo.Pn01.MotorType.Data <= 0)//电机型号错误
	   {
		  Err.MotorTypeErrFlag=1;
	   }
	   if(Err.MotorTypeErrFlag==1 || Err.CurOverFlag==1 || Err.MainCurRefErrFlag==1 || Err.AbsaCrcErrFlag==1)// 电机型糯砦蟊ň肮鞅ň?编码器通信报警
	   {
	      Err.ServoAlarmFlag=1;
	   }

		 if(IoDi.DI_CCWL == 1 && IoDi.DI_CWL == 1)
		 {
				if(Servo.Pn02.CcwCwEnable.Data == 1)
				{
					Err.CcwlCwlErrFlag = 1;
				}
		 }
		 if(pos_sum_ek_out > pos_ek_err || pos_sum_ek_out < -pos_ek_err)
		 {
				if(Servo.Pn01.PosEkSw.Data==0 &&
								Servo.Pn01.ContrlMode.Data != CTL_Pt_Psi &&
								Servo.Pn01.ContrlMode.Data != CTL_Ti &&
								Servo.Pn01.ContrlMode.Data != CTL_PtTi &&
				        Servo.Pn01.ContrlMode.Data != CTL_PtTiCheck)
				{
					 Err.ServoAlarmFlag=1;   //位置超差报警
					 Err.PosEkOverErrorFlag=1;
				}
		 }


		 if(Fn.MotorSpd>Servo.Pn01.SpdMax.Data || Fn.MotorSpd<-Servo.Pn01.SpdMax.Data)
		 {
			 Err.ServoAlarmFlag=1;
			 Err.SpeedHighFlag = 1;
		 }
#if 1
//		 if(gpio_get_val(ioPowerOffIn)==0)//ioPowerOffIn==0主回路掉电
//		 {
//			     if(Servo.Pn02.PowerOffErrorIgore.Data == 0)
//				 {
//						 if(ioPowerOffInDelay >= 10000)
//						 {
//								Err.ServoAlarmFlag=1;
//								Err.maniPower0ffFlag = 1;//主回路断电报警
////								gpio_set_val(ioReLayOut,GPIO_LEVEL_HIGH);//继电器断开
//								IoDo.BRKR = 1;//电机抱闸
//
//						 }
//						 else
//						 {
//								ioPowerOffInDelay++;
//						 }
//				 }
//				 else
//				 {
//					   ioPowerOffInDelay = 0;
//				 }
//		 }
//		 else
		 {
			     ioPowerOffInDelay = 0;

				 if(gpio_get_val(ioPowerHighIn) == 1)
				 {
						Err.MainPowerHighCnt++;
						if(Err.MainPowerHighCnt > Err.MainPowerHighPs)Err.MainPowerHighCnt = Err.MainPowerHighPs + 1;
				 }
				 else
				 {
						Err.MainPowerHighCnt = 0;
				 }
				 if(Err.MainPowerHighCnt>Err.MainPowerHighPs)  //过压报警延时
				 {
						Err.ServoAlarmFlag =1;     //过压故障报警
						Err.MainPowerHighFlag = 1;
				 }

				 if(Servo.Pn02.TmpSampleSw.Data == 0)
				 {
						if(gpio_get_val(ioPowerLowIn) == 1)
						{
							  Err.MainPowerLowCnt++;
							  if(Err.MainPowerLowCnt > Err.MainPowerLowPs)
							  {
								Err.MainPowerLowCnt = Err.MainPowerLowPs+1;
							  }
						}
						else
						{
							  Err.MainPowerLowCnt = 0;
						}
						if(Err.MainPowerLowCnt>Err.MainPowerLowPs)
						{
							  Err.ServoAlarmFlag =1;
							  Err.MainPowerLowFlag=1;
						}
				 }
				 else
				 {
					  if(Fn.VdcInputVol <= Servo.Pn04.MainPowerLowVale.Data)
					  {
						    Err.MainPowerLowCnt++;
						    if(Err.MainPowerLowCnt > Err.MainPowerLowPs)
						    {
							   Err.MainPowerLowCnt = Err.MainPowerLowPs+1;
						    }
					  }
					  else
					  {
							Err.MainPowerLowCnt = 0;
					  }
					  if(Err.MainPowerLowCnt>Err.MainPowerLowPs)
					  {
							Err.ServoAlarmFlag =1;
							Err.MainPowerLowFlag=1;
					  }
					  if(gpio_get_val(ioPowerLowIn) == 1)
					  {
							Err.TempHighCnt++;
							if(Err.TempHighCnt > Err.TempHighPs)
							{
							   Err.TempHighCnt = Err.TempHighPs+1;
							}
					  }
					  else
					  {
							Err.TempHighCnt = 0;
					  }
					  if(Err.TempHighCnt>Err.TempHighPs)
					  {
							Err.ServoAlarmFlag =1;
							Err.TempHighFlag=1;
					  }
                 }

				  if(gpio_get_val(ioBreakErrIn) == 1)
				  {
				      Err.BrakeAlarmCnt++;
				      if(Err.BrakeAlarmCnt > Err.BrakeAlarmPs)Err.BrakeAlarmCnt = Err.BrakeAlarmPs + 1;
				  }
				  else
				  {
				      Err.BrakeAlarmCnt = 0;
				  }
				  if(Err.BrakeAlarmCnt>Err.BrakeAlarmPs)  //制动报警延时
				  {
					  Err.ServoAlarmFlag =1;
					  Err.BrakeAlarmFlag=1;
				  }
	   }
#endif

#if(SDFM_USED == 1)

#else
	   if(ilg2_vdc1.Imeas_ref_ad0 <= ADC_REF_MIN || ilg2_vdc1.Imeas_ref_ad0 >= ADC_REF_MAX)
	   {
			Err.MainCurRefErrFlag = 1;
	   }
	   if(ilg2_vdc1.Imeas_ref_ad1 <= ADC_REF_MIN || ilg2_vdc1.Imeas_ref_ad1 >= ADC_REF_MAX)
	   {
			Err.MainCurRefErrFlag = 1;
	   }

#endif

}
